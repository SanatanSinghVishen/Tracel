# Server environment variables
# Copy to .env

# MongoDB connection string
MONGO_URL=mongodb://localhost:27017/tracel

# AI service endpoint (recommended)
# Use the ai-engine service URL (NOT the backend URL).
# Examples:
# - Local: AI_ENGINE_URL=http://127.0.0.1:5000
# - Render: AI_ENGINE_URL=https://<your-ai-engine-service>.onrender.com
AI_ENGINE_URL=http://127.0.0.1:5000

# Optional override: full predict endpoint
# If set, this takes precedence over AI_ENGINE_URL.
AI_PREDICT_URL=

# Attack-mode tuning (0.0–1.0). Higher => more malicious packets during Attack Mode.
# Default (if unset): 0.6
# Attack mode traffic mix. Accepts either 0..1 (e.g. 0.6) or 0..100 (e.g. 60).
ATTACK_MALICIOUS_RATIO=0.6

# Groq (Chat) configuration
# Required for /api/chat
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Note: Admin access is now managed via Clerk roles.
# Assign the "org:admin" role or publicMetadata.role="admin" to your user in the Clerk Dashboard.

# If you use Clerk for auth, set the JWKS URL for token verification.
# This is required for verified JWTs and for admin-only endpoints.
# How to find it:
# 1) Sign in on the dashboard so requests include a Bearer token.
# 2) Decode the JWT payload (no secret needed) and read the `iss` claim.
# 3) Set JWKS URL to: <iss> + "/.well-known/jwks.json"
# You can also find the issuer/domain in the Clerk dashboard.
# Example (do not copy blindly — use your instance's URL):
# CLERK_JWKS_URL=https://clerk.your-domain/.well-known/jwks.json
CLERK_JWKS_URL=

# Optional logging level: debug | info | warn | error
TRACEL_LOG_LEVEL=info

MEMORY_STORE_MAX_SIZE=1000
MEMORY_STORE_TTL_MINUTES=30

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_HTTP=200
RATE_LIMIT_MAX_ADMIN=20
SOCKET_MAX_CONNECTIONS_PER_WINDOW=10
SOCKET_WINDOW_MS=60000

# Server port
PORT=3001

# AI Engine specific configuration
UVICORN_WORKERS=1
# CORS Configuration
FRONTEND_URL=https://tracel.vercel.app

# Database Configuration
MONGO_POOL_SIZE=10

TRACEL_LOG_LEVEL=info

# Timeout in milliseconds to wait for the AI Engine worker to score a packet via Redis
AI_RESULT_TIMEOUT_MS=10000
